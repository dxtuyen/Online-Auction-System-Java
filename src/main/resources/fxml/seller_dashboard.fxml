<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.auction.client.controller.SellerDashboardController"
            prefWidth="920" prefHeight="620"
            style="-fx-background-color: #f8fafc;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="header-bar">
            <Button text="← Quay lại" onAction="#goBack" styleClass="btn-secondary"/>
            <Label text="🏪 Dashboard người bán" styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblUserInfo" styleClass="muted-label"/>
            <Button text="Tài khoản" onAction="#handleViewAccount" styleClass="btn-secondary"/>
        </HBox>
    </top>

    <center>
        <HBox spacing="16">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

            <!-- LEFT: danh sách sản phẩm + tạo phiên -->
            <VBox spacing="12" prefWidth="440" styleClass="card">
                <Label text="📦 Sản phẩm của tôi" style="-fx-font-weight: bold;"/>
                <TableView fx:id="tblItems" prefHeight="220">
                    <columns>
                        <TableColumn fx:id="colItemId" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="colItemName" text="Tên" prefWidth="200"/>
                        <TableColumn fx:id="colItemPrice" text="Giá KĐ" prefWidth="140"/>
                    </columns>
                    <placeholder><Label text="Chưa có sản phẩm"/></placeholder>
                </TableView>

                <Separator/>
                <Label text="🏛️ Tạo phiên đấu giá" style="-fx-font-weight: bold;"/>
                <GridPane hgap="8" vgap="8">
                    <columnConstraints>
                        <ColumnConstraints minWidth="120"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>
                    <Label text="Item ID:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="txtAuctionItemId" styleClass="text-input"
                               GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <Label text="Thời gian (phút):" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="txtDuration" text="30" styleClass="text-input"
                               GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    <Label text="Bước nhảy (VNĐ):" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <TextField fx:id="txtMinIncrement" text="500000" styleClass="text-input"
                               GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                </GridPane>
                <Button text="Tạo phiên đấu giá" onAction="#handleCreateAuction"
                        maxWidth="Infinity" styleClass="btn-primary"/>
                <Label fx:id="lblAuctionStatus" styleClass="muted-label" wrapText="true"/>
            </VBox>

            <!-- RIGHT: tạo sản phẩm mới -->
            <VBox spacing="10" HBox.hgrow="ALWAYS" styleClass="card">
                <Label text="➕ Thêm sản phẩm mới" style="-fx-font-weight: bold;"/>

                <Label text="Danh mục:"/>
                <ComboBox fx:id="cboCategory" prefWidth="200">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="ELECTRONICS"/>
                            <String fx:value="ART"/>
                            <String fx:value="VEHICLE"/>
                            <String fx:value="FASHION"/>
                            <String fx:value="COLLECTIBLE"/>
                            <String fx:value="OTHER"/>
                        </FXCollections>
                    </items>
                </ComboBox>

                <Label text="Tên sản phẩm:"/>
                <TextField fx:id="txtName" styleClass="text-input"/>

                <Label text="Mô tả:"/>
                <TextArea fx:id="txtDesc" prefHeight="60"/>

                <Label text="Giá khởi điểm (VNĐ):"/>
                <TextField fx:id="txtStartPrice" styleClass="text-input"/>

                <Label text="Tình trạng:"/>
                <ComboBox fx:id="cboCondition" prefWidth="200">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="NEW"/>
                            <String fx:value="USED"/>
                        </FXCollections>
                    </items>
                </ComboBox>

                <Label text="Thuộc tính (tùy chọn):"/>
                <TextField fx:id="txtBrand" promptText="Hãng/Tác giả" styleClass="text-input"/>
                <TextField fx:id="txtModel" promptText="Model/Năm" styleClass="text-input"/>

                <Button text="Thêm sản phẩm" onAction="#handleCreateItem"
                        maxWidth="Infinity" styleClass="btn-primary"/>
                <Label fx:id="lblItemStatus" styleClass="muted-label" wrapText="true"/>
            </VBox>
        </HBox>
    </center>
</BorderPane>
