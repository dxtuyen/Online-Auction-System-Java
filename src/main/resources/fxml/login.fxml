<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.auction.client.controller.LoginController"
            prefWidth="920" prefHeight="620"
            style="-fx-background-color: #f8fafc;">

    <center>
        <VBox alignment="CENTER" spacing="14" maxWidth="380" styleClass="card">
            <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

            <Label text="🏛️" style="-fx-font-size: 44;"/>
            <Label text="Hệ thống Đấu giá Trực tuyến"
                   style="-fx-font-size: 20; -fx-font-weight: bold;"/>
            <Label text="Đăng nhập để tiếp tục" styleClass="muted-label"/>

            <Region prefHeight="8"/>

            <TextField fx:id="txtUsername" promptText="Tên đăng nhập"
                       prefHeight="40" styleClass="text-input"/>
            <PasswordField fx:id="txtPassword" promptText="Mật khẩu"
                           prefHeight="40" styleClass="text-input"/>

            <Label fx:id="lblError" styleClass="error-label" wrapText="true"/>

            <ProgressIndicator fx:id="spinLoading" visible="false"
                               prefWidth="24" prefHeight="24"/>

            <Button fx:id="btnLogin" text="Đăng nhập"
                    onAction="#handleLogin"
                    prefWidth="320" prefHeight="40" styleClass="btn-primary"/>

            <HBox alignment="CENTER" spacing="4">
                <Label text="Chưa có tài khoản?" styleClass="muted-label"/>
                <Hyperlink text="Đăng ký" onAction="#goToRegister"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
