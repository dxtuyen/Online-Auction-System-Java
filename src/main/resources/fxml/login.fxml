<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="500.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.LoginController">
    <children>
        <!-- VBox này là lớp nền, phủ kín toàn bộ cửa sổ và làm nhiệm vụ căn giữa -->
        <VBox alignment="CENTER" style="-fx-background-color: #f1f5f9;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>

                <!-- card trắng-->
                <VBox alignment="TOP_CENTER" maxWidth="400.0" prefWidth="350.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: #e2e8f0; -fx-border-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                    <padding>
                        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                    </padding>
                    <children>

                        <Label text="Sign In" textFill="#000000d1">
                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>
                        </Label>

                        <!-- Form nhập tên đăng nhập -->
                        <VBox spacing="5.0">
                            <children>
                                <Label text="Tên đăng nhập" textFill="#64748b" />
                                <TextField fx:id="txtUsername" prefHeight="40.0" promptText="Nhập tên đăng nhập" style="-fx-background-radius: 8; -fx-border-color: #cbd5e1; -fx-border-radius: 8;" />
                            </children>
                        </VBox>

                        <!-- Form nhập mật khẩu -->
                        <VBox spacing="5.0">
                            <children>
                                <Label text="Mật khẩu" textFill="#64748b" />
                                <PasswordField fx:id="txtPassword" prefHeight="40.0" promptText="••••••••" style="-fx-background-radius: 8; -fx-border-color: #cbd5e1; -fx-border-radius: 8;" />
                            </children>
                        </VBox>

                        <!-- nút đăng nhâp-->
                        <Button fx:id="btnLogin" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogin" prefHeight="45.0" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="Đăng nhập">
                            <font>
                                <Font size="14.0" />
                            </font>
                            <VBox.margin>
                                <Insets top="10.0" />
                            </VBox.margin>
                        </Button>

                        <!-- link chuyển sang màn hình đăng kí-->
                        <HBox alignment="CENTER" spacing="5.0">
                            <children>
                                <Label text="Chưa có tài khoản?" textFill="#64748b" />
                                <Hyperlink onAction="#handleShowRegister" style="-fx-underline: false;" text="Đăng ký ngay" textFill="#2563eb" />
                            </children>
                        </HBox>

                    </children>
                </VBox>

            </children>
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
        </VBox>
    </children>
</AnchorPane>
