<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.auction.client.controller.AuctionListController"
            prefWidth="920" prefHeight="620"
            style="-fx-background-color: #f8fafc;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="header-bar">
            <Label text="🏛️ Đấu giá Trực tuyến" styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblUserInfo" styleClass="muted-label"/>
            <Button fx:id="btnCreateAuction" text="+ Tạo phiên"
                    onAction="#goToSellerDashboard" visible="false"
                    styleClass="btn-secondary"/>
            <Button text="Đăng xuất" onAction="#handleLogout" styleClass="btn-secondary"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="12">
            <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="txtSearch" promptText="🔍 Tìm theo tên / ID..."
                           prefWidth="320" prefHeight="34" styleClass="text-input"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="🔄 Refresh" onAction="#handleRefresh" styleClass="btn-secondary"/>
            </HBox>

            <TableView fx:id="tblAuctions" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="colItem" text="Sản phẩm" prefWidth="260"/>
                    <TableColumn fx:id="colCategory" text="Danh mục" prefWidth="120"/>
                    <TableColumn fx:id="colPrice" text="Giá hiện tại" prefWidth="160"/>
                    <TableColumn fx:id="colBids" text="Lượt bid" prefWidth="90"/>
                    <TableColumn fx:id="colStatus" text="Trạng thái" prefWidth="150"/>
                </columns>
                <placeholder><Label text="Chưa có phiên đấu giá"/></placeholder>
            </TableView>

            <Label text="💡 Double-click vào phiên để vào đấu giá"
                   styleClass="muted-label"/>
        </VBox>
    </center>
</BorderPane>
