<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.auction.client.controller.BiddingController"
            prefWidth="920" prefHeight="620"
            style="-fx-background-color: #f8fafc;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="header-bar">
            <Button text="← Quay lại" onAction="#goBack" styleClass="btn-secondary"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblTimer" styleClass="timer-normal"/>
        </HBox>
    </top>

    <center>
        <HBox spacing="16">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

            <!-- LEFT: thông tin + bid -->
            <VBox spacing="12" prefWidth="420" styleClass="card">
                <Label fx:id="lblItemName" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
                <Label fx:id="lblItemInfo" wrapText="true" styleClass="muted-label"/>

                <Separator/>

                <GridPane hgap="12" vgap="8">
                    <columnConstraints>
                        <ColumnConstraints minWidth="120"/>
                        <ColumnConstraints/>
                    </columnConstraints>
                    <Label text="Giá khởi điểm:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <Label fx:id="lblStartPrice" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <Label text="Giá hiện tại:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <Label fx:id="lblCurrentPrice" styleClass="price-big"
                           GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    <Label text="Bước nhảy:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <Label fx:id="lblIncrement" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    <Label text="Lượt bid:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <Label fx:id="lblBidCount" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                    <Label text="Dẫn đầu:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                    <Label fx:id="lblLeader" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                </GridPane>

                <Separator/>

                <Label text="💰 Đặt giá" style="-fx-font-weight: bold;"/>
                <HBox spacing="8">
                    <TextField fx:id="txtBidAmount" promptText="Nhập giá..."
                               prefHeight="38" HBox.hgrow="ALWAYS" styleClass="text-input"/>
                    <Button fx:id="btnPlaceBid" text="Đặt giá"
                            onAction="#handlePlaceBid" prefHeight="38" styleClass="btn-primary"/>
                </HBox>
                <Label fx:id="lblError" styleClass="error-label" wrapText="true"/>

                <Separator/>

                <!-- Auto-bid (Phase 4) -->
                <Label text="🤖 Auto-Bid" style="-fx-font-weight: bold;"/>
                <HBox spacing="8">
                    <TextField fx:id="txtMaxBid" promptText="Giá tối đa"
                               HBox.hgrow="ALWAYS" styleClass="text-input"/>
                    <TextField fx:id="txtIncrementAuto" promptText="Bước nhảy"
                               HBox.hgrow="ALWAYS" styleClass="text-input"/>
                    <Button text="Đăng ký" onAction="#handleSetAutoBid" styleClass="btn-secondary"/>
                </HBox>
                <Label fx:id="lblAutoBidStatus" styleClass="muted-label"/>
            </VBox>

            <!-- RIGHT: LineChart + History -->
            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <Label text="📈 Biểu đồ giá" style="-fx-font-weight: bold;"/>
                <LineChart fx:id="chartPrice" animated="false" createSymbols="true"
                           prefHeight="260" legendVisible="false">
                    <xAxis><CategoryAxis fx:id="xAxis" label="Thời gian"/></xAxis>
                    <yAxis><NumberAxis fx:id="yAxis" label="Giá (VNĐ)"/></yAxis>
                </LineChart>

                <Label text="📜 Lịch sử đặt giá" style="-fx-font-weight: bold;"/>
                <ListView fx:id="lstBidHistory" VBox.vgrow="ALWAYS"/>
            </VBox>
        </HBox>
    </center>
</BorderPane>
